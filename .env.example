# ==================================================
# M PAIVA Learning OS — ambiente seguro
# NÃO colocar valores reais no GitHub
# NÃO usar prefixo VITE_ para segredos
# ==================================================

# Certificado público Alura
ALURA_CERTIFICATE_URL=https://cursos.alura.com.br/user/mpaiiva21/fullCertificate/ff76f7f854b9406caa12231528651a92
ALURA_PUBLIC_PROFILE_URL=https://cursos.alura.com.br/user/mpaiiva21/

# Cron interno do Vercel
CRON_SECRET=troque-por-um-token-longo

# API Dashboard Alura — fonte oficial para slugs, progresso, cursos em andamento e guides
# Marque como Sensitive na Vercel. Não usar VITE_.
ALURA_DASHBOARD_API_TOKEN=
ALURA_DASHBOARD_API_URL=

# Sincronização privada Alura
ALURA_PRIVATE_SYNC=false

# Opções: credentials, cookie-or-json
# credentials tenta login server-side com variáveis sensíveis da Vercel.
ALURA_AUTH_MODE=cookie-or-json
ALURA_USER_SLUG=mpaiiva21

# Modo cookie: sessão copiada do navegador e salva como variável sensível na Vercel.
# Não colocar esse valor no código, zip público ou README.
ALURA_SESSION_COOKIE=

# Alternativa segura: JSON sanitizado com cursos em andamento/carreiras oficiais.
# Exemplo: {"inProgressCourses":[{"title":"Curso X","progress":42}],"officialCareers":[{"name":"Especialista em IA","officialProgress":48}]}
ALURA_PRIVATE_PROGRESS_JSON=

# Modo credentials: usar somente como Environment Variables sensíveis na Vercel.
# Nunca usar VITE_ALURA_EMAIL ou VITE_ALURA_PASSWORD.
ALURA_EMAIL=
ALURA_PASSWORD=
